From c5881dd4e2f5e46df34b1a2bdf9409504168991b Mon Sep 17 00:00:00 2001
From: George Huebner <george@feyor.sh>
Date: Mon, 2 Feb 2026 11:11:58 -0600
Subject: [PATCH] gdb: fix build on clang

---
 pkgs/by-name/gd/gdb/package.nix | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pkgs/by-name/gd/gdb/package.nix b/pkgs/by-name/gd/gdb/package.nix
index 8b1d613b80435..f0fc625aff49a 100644
--- a/pkgs/by-name/gd/gdb/package.nix
+++ b/pkgs/by-name/gd/gdb/package.nix
@@ -159,7 +159,7 @@ stdenv.mkDerivation (finalAttrs: {
     # subset of the platform description.
     "--program-prefix=${targetPrefix}"
 
-    (enableFeature true "werror")
+    (enableFeature false "werror")
     (enableFeature true "64-bit-bfd")
     (enableFeature false "install-libbfd")
     (enableFeature withTui "tui")
